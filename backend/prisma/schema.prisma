// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum Role {
  INSTRUCTOR
  STUDENT
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SessionStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  EXPIRED
}

// ============================================
// MODELS
// ============================================

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique @db.VarChar(255)
  passwordHash    String    @map("password_hash") @db.VarChar(255)
  fullName        String    @map("full_name") @db.VarChar(255)
  phone           String?   @db.VarChar(20)
  avatarUrl       String?   @map("avatar_url") @db.VarChar(500)
  role            Role      @default(STUDENT)
  isActive        Boolean   @default(true) @map("is_active")
  emailVerifiedAt DateTime? @map("email_verified_at")

  // Email verification
  emailVerifyToken     String?   @unique @map("email_verify_token") @db.VarChar(255)
  emailVerifyExpiresAt DateTime? @map("email_verify_expires_at")

  // Password reset
  passwordResetToken     String?   @unique @map("password_reset_token") @db.VarChar(255)
  passwordResetExpiresAt DateTime? @map("password_reset_expires_at")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  refreshTokens RefreshToken[]
  courses       Course[]       @relation("InstructorCourses")
  enrollments   Enrollment[]
  feedbacks     Feedback[]
  auditLogs     AuditLog[]
  gradesGiven   Grade[]        @relation("GradedBy")

  @@index([email])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

model Course {
  id               String       @id @default(uuid()) @db.Uuid
  instructorId     String       @map("instructor_id") @db.Uuid
  title            String       @db.VarChar(255)
  description      String       @db.Text
  shortDescription String?      @map("short_description") @db.VarChar(500)
  price            Decimal      @db.Decimal(12, 2)
  maxParticipants  Int          @map("max_participants")
  thumbnailUrl     String?      @map("thumbnail_url") @db.VarChar(500)
  status           CourseStatus @default(DRAFT)
  category         String?      @db.VarChar(100)
  publishedAt      DateTime?    @map("published_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  // Relations
  instructor  User            @relation("InstructorCourses", fields: [instructorId], references: [id])
  sessions    CourseSession[]
  enrollments Enrollment[]
  feedbacks   Feedback[]

  @@index([instructorId])
  @@index([status])
  @@index([category])
  @@map("courses")
}

model CourseSession {
  id            String        @id @default(uuid()) @db.Uuid
  courseId       String        @map("course_id") @db.Uuid
  title         String        @db.VarChar(255)
  description   String?       @db.Text
  sessionDate   DateTime      @map("session_date") @db.Date
  startTime     String        @map("start_time") @db.VarChar(10)
  endTime       String        @map("end_time") @db.VarChar(10)
  zoomLink      String?       @map("zoom_link") @db.VarChar(500)
  zoomMeetingId String?       @map("zoom_meeting_id") @db.VarChar(100)
  status        SessionStatus @default(SCHEDULED)
  sessionOrder  Int           @map("session_order")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relations
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([sessionDate])
  @@index([status])
  @@map("course_sessions")
}

model Enrollment {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  courseId     String           @map("course_id") @db.Uuid
  status      EnrollmentStatus @default(PENDING)
  enrolledAt  DateTime         @default(now()) @map("enrolled_at")
  completedAt DateTime?        @map("completed_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  // Relations
  user        User         @relation(fields: [userId], references: [id])
  course      Course       @relation(fields: [courseId], references: [id])
  payment     Payment?
  grade       Grade?
  certificate Certificate?

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([status])
  @@map("enrollments")
}

model Payment {
  id                    String        @id @default(uuid()) @db.Uuid
  enrollmentId          String        @unique @map("enrollment_id") @db.Uuid
  userId                String        @map("user_id") @db.Uuid
  orderId               String        @unique @map("order_id") @db.VarChar(100)
  amount                Decimal       @db.Decimal(12, 2)
  status                PaymentStatus @default(PENDING)
  paymentMethod         String?       @map("payment_method") @db.VarChar(50)
  midtransTransactionId String?       @map("midtrans_transaction_id") @db.VarChar(100)
  midtransSnapToken     String?       @map("midtrans_snap_token") @db.VarChar(500)
  midtransSnapUrl       String?       @map("midtrans_snap_url") @db.VarChar(500)
  midtransResponse      Json?         @map("midtrans_response")
  paidAt                DateTime?     @map("paid_at")
  expiredAt             DateTime?     @map("expired_at")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  // Relations
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])

  @@index([orderId])
  @@index([status])
  @@index([userId])
  @@map("payments")
}

model Grade {
  id           String   @id @default(uuid()) @db.Uuid
  enrollmentId String   @unique @map("enrollment_id") @db.Uuid
  gradedById   String   @map("graded_by") @db.Uuid
  score        Decimal  @db.Decimal(5, 2)
  letterGrade  String?  @map("letter_grade") @db.VarChar(5)
  notes        String?  @db.Text
  gradedAt     DateTime @default(now()) @map("graded_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])
  gradedBy   User       @relation("GradedBy", fields: [gradedById], references: [id])

  @@index([enrollmentId])
  @@map("grades")
}

model Certificate {
  id                String   @id @default(uuid()) @db.Uuid
  enrollmentId      String   @unique @map("enrollment_id") @db.Uuid
  certificateNumber String   @unique @map("certificate_number") @db.VarChar(50)
  fileUrl           String?  @map("file_url") @db.VarChar(500)
  certificateData   Json?    @map("certificate_data")
  issuedAt          DateTime @default(now()) @map("issued_at")
  createdAt         DateTime @default(now()) @map("created_at")

  // Relations
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])

  @@index([certificateNumber])
  @@map("certificates")
}

model Feedback {
  id          String   @id @default(uuid()) @db.Uuid
  enrollmentId String? @map("enrollment_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  courseId     String   @map("course_id") @db.Uuid
  rating      Int      @db.SmallInt
  comment     String?  @db.Text
  isAnonymous Boolean  @default(false) @map("is_anonymous")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@index([courseId])
  @@index([userId])
  @@map("feedbacks")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(50)
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.Uuid
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
